<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardWord"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Her zaman görünür kısım -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/textViewWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Word"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <ImageButton
                android:id="@+id/btnSpeakItem"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_speaker"
                app:tint="#424242"
                android:contentDescription="Listen pronunciation" />
        </RelativeLayout>

        <TextView
            android:id="@+id/textViewMeaning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Anlamı"
            android:textSize="17sp"
            android:textColor="#2E7D32"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>

        <!-- Tıklandığında açılacak detay kısmı -->
        <LinearLayout
            android:id="@+id/layoutDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginVertical="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Definition:"
                android:textSize="12sp"
                android:textColor="#757575"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textViewDefinition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="English definition of the word."
                android:textSize="14sp"
                android:textColor="#424242"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Example:"
                android:textSize="12sp"
                android:textColor="#757575"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textViewExampleEn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The example sentence in English."
                android:textSize="14sp"
                android:textColor="#424242"
                android:textStyle="italic"/>

            <TextView
                android:id="@+id/textViewExampleTr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Örnek cümlenin Türkçe çevirisi."
                android:textSize="13sp"
                android:textColor="#616161"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Synonyms:"
                android:textSize="12sp"
                android:textColor="#757575"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/textViewSynonyms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="synonym 1, synonym 2..."
                android:textSize="14sp"
                android:textColor="#E91E63"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
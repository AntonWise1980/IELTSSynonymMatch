<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="0dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#BBDEFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#E3F2FD">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Akademik Veritabanı Analizi"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#1565C0"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bu kütüphane, IELTS sınavının C1 seviyesindeki en zorlayıcı fiillerinden oluşmaktadır. Kelime seçimlerimiz; bilimsel makaleler, sosyal analizler ve üst düzey akademik yayınlar taranarak titizlikle belirlenmiştir. 'Substantiate', 'Contemplate' ve 'Articulate' gibi eylemler, sadece birer kelime değil; fikirlerinizi kanıta dayalı, derinlikli ve net bir şekilde ifade etmenizi sağlayan profesyonel araçlardır. Bu veritabanı, sadece sınavı geçmeniz için değil, akademik dünyada kendinizi ifade edebilmeniz için tasarlanmıştır."
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:textColor="#0D47A1"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
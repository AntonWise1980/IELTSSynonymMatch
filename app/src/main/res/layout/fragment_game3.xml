<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Oyun Ekranı (Başlangıçta Gizli) -->
    <LinearLayout
        android:id="@+id/layoutGame3Content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center"
        android:visibility="gone">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/textViewLives3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❤️❤️❤️❤️❤️"
                android:textSize="20sp"
                android:layout_alignParentStart="true" />

            <TextView
                android:id="@+id/textViewQuestionCount3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kalan Soru: 155"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_centerHorizontal="true" />

            <TextView
                android:id="@+id/textViewScore3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Puan: 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <TextView
            android:id="@+id/textViewDefinition3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Definition will appear here..."
            android:textSize="18sp"
            android:textStyle="italic"
            android:textColor="#444444"
            android:textAlignment="center"
            android:layout_marginBottom="12dp"
            android:background="#F5F5F5"
            android:padding="12dp"/>

        <TextView
            android:id="@+id/textViewExample3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Example sentence will appear here..."
            android:textSize="15sp"
            android:textColor="#666666"
            android:textAlignment="center"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="12dp"/>

        <TextView
            android:id="@+id/textViewSynonyms3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Synonyms: ..."
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#E91E63"
            android:textAlignment="center"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnOption1_3"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="10dp"
            android:text="Seçenek 1"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btnOption2_3"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="10dp"
            android:text="Seçenek 2"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btnOption3_3"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="10dp"
            android:text="Seçenek 3"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btnOption4_3"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="10dp"
            android:text="Seçenek 4"
            android:textAllCaps="false"/>

        <Button
            android:id="@+id/btnEndGame3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Oyunu Bitir"
            android:backgroundTint="#FF5252"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <!-- Bilgi ve Başlatma Ekranı (Başlangıçta Görünür) -->
    <LinearLayout
        android:id="@+id/layoutIntro3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="30dp"
        android:gravity="center"
        android:background="@android:color/white">

        <TextView
            android:id="@+id/textViewInfo3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Oyun 3: Definition Challenge. Size bir kelimenin İngilizce tanımı (Definition) ve eş anlamlıları verilecek. Sizden bu tanıma uyan ana kelimeyi seçenekler arasından bulmanız istenecek. Başarıya ulaşmak için 5 hakkınız vardır."
            android:textSize="18sp"
            android:textAlignment="center"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/black"
            android:layout_marginBottom="40dp" />

        <Button
            android:id="@+id/btnPlayGame3"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="Play"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>